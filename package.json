    "pg": "^8.22.0",
    "socket.io": "^4.7.5",
    "socket.io-client-v2": "npm:socket.io-client@^2.0.3",
    "three": "^0.185.1",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@types/three": "^0.185.1",
    "@types/ws": "^8.5.10",
