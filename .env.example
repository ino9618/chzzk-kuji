PORT=3000
CHZZK_CLIENT_ID=
CHZZK_CLIENT_SECRET=
CHZZK_REDIRECT_URI=http://localhost:3000/api/chzzk/oauth/callback
TOKEN_ENCRYPTION_KEY=
ADMIN_PASSWORD=
# Supabase Postgres connection string (Dashboard -> Connect -> Session pooler URI).
# The same URL is used for local runs and the deployed server, so both see the same data.
DATABASE_URL=
# Server-only Google Cloud Text-to-Speech API key. Restrict it to the
# Cloud Text-to-Speech API and the deployed server before production use.
GOOGLE_CLOUD_TTS_API_KEY=
